<div class="rt-story-wrapper" id="rt-intro">
  <div class="rt-intro">
    <div class="rt-story-container">
      <div class="rt-intro-grid">
        <div class="rt-intro-img rt-reveal-left">
          {%- if section.settings.image != blank -%}
            <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy">
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        
        <div class="rt-intro-content-wrapper rt-reveal-right">
          <span class="rt-section-eyebrow">{{ section.settings.eyebrow | escape }}</span>
          <h2 class="rt-section-title">{{ section.settings.heading | escape }}</h2>
          <div class="rt-intro-desc">
            {{ section.settings.description }}
          </div>
          
          <div class="rt-intro-cards">
            {%- for block in section.blocks -%}
              <div class="rt-intro-card">
                <div class="rt-intro-card-num">{{ block.settings.number | escape }}</div>
                <div class="rt-intro-card-label">{{ block.settings.label | escape }}</div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Our Story Who We Are",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Luxury Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "WHO WE ARE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Every Timepiece Has A Story"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>At RoyalTick, we believe a watch is more than an instrument of time; it is a legacy passed down through generations. Founded on the principles of authenticity, master craftsmanship, and timeless style, we curate only the world's most exceptional timepieces.</p>"
    }
  ],
  "blocks": [
    {
      "type": "stat_card",
      "name": "Statistic Card",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "10+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Years Experience"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Story Who We Are",
      "blocks": [
        {
          "type": "stat_card",
          "settings": {
            "number": "10+",
            "label": "Years Experience"
          }
        },
        {
          "type": "stat_card",
          "settings": {
            "number": "2500+",
            "label": "Luxury Watches"
          }
        },
        {
          "type": "stat_card",
          "settings": {
            "number": "150+",
            "label": "Brands"
          }
        },
        {
          "type": "stat_card",
          "settings": {
            "number": "5000+",
            "label": "Happy Customers"
          }
        }
      ]
    }
  ]
}
{% endschema %}
