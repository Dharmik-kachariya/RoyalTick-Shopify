{{ 'rt-collections.css' | asset_url | stylesheet_tag }}
<script src="{{ 'rt-collections.js' | asset_url }}" defer="defer"></script>

<script
  src="{{ 'results-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- style -%}
  #rt-collections-{{ section.id }} {
    --rt-bg-color: {{ section.settings.rt_background_color }};
    --rt-accent-color: {{ section.settings.rt_accent_color }};
    --rt-accent-glow: {{ section.settings.rt_accent_color | color_modify: 'alpha', 0.15 }};
    --rt-columns-desktop: {{ section.settings.rt_columns_desktop }};
    --rt-columns-mobile: {{ section.settings.rt_columns_mobile }};
  }
{%- endstyle -%}

<div 
  id="rt-collections-{{ section.id }}" 
  class="rt-collections-container"
  data-enable-animation="{{ section.settings.rt_enable_animation }}"
>
  
  <!-- SECTION 1: Luxury Hero Banner -->
  <div class="rt-collection-hero">
    {%- if section.settings.rt_banner_video != blank -%}
      {{
        section.settings.rt_banner_video
        | video_tag:
          poster: nil,
          autoplay: true,
          loop: true,
          controls: false,
          muted: true,
          class: 'rt-collection-hero__video'
      }}
    {%- elsif section.settings.rt_banner_image != blank -%}
      <div class="rt-collection-hero__banner" style="background-image: url('{{ section.settings.rt_banner_image | image_url: width: 1800 }}');"></div>
    {%- else -%}
      <div class="rt-collection-hero__banner" style="background-image: url('{{ collection.image | image_url: width: 1800 }}');"></div>
    {%- endif -%}
    <div class="rt-collection-hero__overlay"></div>
    
    <div class="rt-collection-hero__content rt-collection-anim rt-fade-up">
      <span class="rt-collection-hero__eyebrow">Limited Edition</span>
      <h1 class="rt-collection-hero__title">
        {%- if section.settings.rt_page_heading != blank -%}
          {{ section.settings.rt_page_heading | escape }}
        {%- else -%}
          {{ collection.title | escape }}
        {%- endif -%}
      </h1>
      
      {%- if section.settings.rt_show_description and collection.description != blank or section.settings.rt_page_description != blank -%}
        <div class="rt-collection-hero__desc">
          {%- if section.settings.rt_page_description != blank -%}
            {{ section.settings.rt_page_description }}
          {%- else -%}
            {{ collection.description }}
          {%- endif -%}
        </div>
      {%- endif -%}

      <a href="#rt-collection-list-main" class="rt-collection-hero__btn">
        Explore Collection
      </a>
      <div class="rt-collection-hero__divider"></div>
    </div>
  </div>

  <!-- SECTION 2: Horizontal Luxury Category Navigation -->
  {%- assign rt_categories = "all:All Watches,automatic:Automatic,chronograph:Chronograph,skeleton:Skeleton,gmt:GMT,sports:Sports,dress:Dress,swiss:Swiss,limited-edition:Limited Edition" | split: "," -%}
  <div class="rt-category-nav rt-collection-anim rt-fade-up">
    <div class="rt-category-nav__scroll">
      {%- for cat in rt_categories -%}
        {%- assign parts = cat | split: ":" -%}
        {%- assign handle = parts[0] -%}
        {%- assign title = parts[1] -%}
        
        {%- assign is_active = false -%}
        {%- if handle == 'all' and collection.handle == 'all' -%}
          {%- assign is_active = true -%}
        {%- elsif collection.handle == handle -%}
          {%- assign is_active = true -%}
        {%- endif -%}
        
        {%- assign url = "/collections/" | append: handle -%}
        {%- if handle == 'all' -%}
          {%- assign url = routes.all_products_collection_url -%}
        {%- endif -%}
        
        <a href="{{ url }}" data-category="{{ handle }}" class="rt-category-nav__link{% if is_active %} is-active{% endif %}">
          {{ title }}
        </a>
      {%- endfor -%}
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const categoryLinks = document.querySelectorAll(".rt-category-nav__link");
      const productItems = document.querySelectorAll(".rt-product-grid__item");

      categoryLinks.forEach(link => {
        link.addEventListener("click", function(e) {
          e.preventDefault();
          
          // Remove active class from all links
          categoryLinks.forEach(l => l.classList.remove("is-active"));
          
          // Add active class to clicked link
          this.classList.add("is-active");

          const selectedCategory = this.getAttribute("data-category").toLowerCase();

          productItems.forEach(item => {
            const tags = item.getAttribute("data-product-tags") || "";
            const title = item.getAttribute("data-product-title").toLowerCase() || "";
            const type = item.getAttribute("data-product-type") || "";
            
            // If 'all' is selected, show everything
            if (selectedCategory === "all") {
              item.style.display = "";
            } else {
              // Check if the category matches a tag, type, or is in the title
              const matchesTag = tags.includes(selectedCategory);
              const matchesType = type.includes(selectedCategory);
              const matchesTitle = title.includes(selectedCategory);
              const matchesSpecial = selectedCategory === "limited-edition" && (tags.includes("limited") || title.includes("limited"));
              
              if (matchesTag || matchesType || matchesTitle || matchesSpecial) {
                item.style.display = "";
              } else {
                item.style.display = "none";
              }
            }
          });
        });
      });

      // Grid Layout Toggles
      const gridBtns = document.querySelectorAll(".rt-grid-btn");
      const productGrid = document.querySelector(".rt-product-grid");

      // Update button colors on click and toggle grid classes
      gridBtns.forEach(btn => {
        btn.addEventListener("click", function() {
          gridBtns.forEach(b => {
            b.classList.remove("is-active");
            b.style.color = "#888";
          });
          
          this.classList.add("is-active");
          this.style.color = "var(--rt-gold, #cfa85e)"; // Active gold color
          
          if (this.dataset.layout === "dense") {
            productGrid.classList.add("rt-product-grid--dense");
          } else {
            productGrid.classList.remove("rt-product-grid--dense");
          }
        });
      });
      
      // Initialize active state color
      const activeBtn = document.querySelector(".rt-grid-btn.is-active");
      if (activeBtn) activeBtn.style.color = "var(--rt-gold, #cfa85e)";

    });
  </script>

  <!-- SECTION 3: Premium Sticky Filter Bar & Product grid container -->
  <div id="rt-collection-list-main" class="rt-collections-wrapper">
    
    <collection-component view-event-payload="{{ collection | standard_event_data: 'view' | escape }}">
      <results-list
        class="product-grid-container"
        section-id="{{ section.id }}"
        infinite-scroll="{{ section.settings.enable_infinite_scroll }}"
      >
        {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

        <!-- Filter bar -->
        <div class="rt-filter-bar">
          <div class="rt-filter-bar__inner">
            
            <!-- Standard Shopify Facets/Filters -->
            <div class="rt-filter-bar__facets">
              {% content_for 'block',
                type: 'filters',
                id: 'filters',
                results: collection,
                results_size: collection.products_count
              %}
            </div>
            
            <!-- Live Instant Search Bar & Grid Toggles -->
            <div class="rt-collection-search-wrapper" style="display: flex; align-items: center; gap: 1rem;">
              <div class="rt-collection-search">
                <span class="rt-search-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                  </svg>
                </span>
                <input 
                  type="text" 
                  id="rt-collection-search-input" 
                  class="rt-search-input" 
                  placeholder="Search collection..."
                  aria-label="Search items in this collection"
                />
              </div>

              <!-- Grid Density Toggles -->
              <div class="rt-grid-toggles" style="display: flex; gap: 0.5rem; align-items: center;">
                <button type="button" class="rt-grid-btn is-active" data-layout="default" aria-label="Default View" style="background: transparent; border: none; cursor: pointer; color: #888; padding: 0.25rem; transition: color 0.3s ease;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7" rx="1.5"></rect>
                    <rect x="14" y="3" width="7" height="7" rx="1.5"></rect>
                    <rect x="3" y="14" width="7" height="7" rx="1.5"></rect>
                    <rect x="14" y="14" width="7" height="7" rx="1.5"></rect>
                  </svg>
                </button>
                <button type="button" class="rt-grid-btn" data-layout="dense" aria-label="Dense View" style="background: transparent; border: none; cursor: pointer; color: #888; padding: 0.25rem; transition: color 0.3s ease;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="6" cy="6" r="1.5"></circle>
                    <circle cx="12" cy="6" r="1.5"></circle>
                    <circle cx="18" cy="6" r="1.5"></circle>
                    <circle cx="6" cy="12" r="1.5"></circle>
                    <circle cx="12" cy="12" r="1.5"></circle>
                    <circle cx="18" cy="12" r="1.5"></circle>
                    <circle cx="6" cy="18" r="1.5"></circle>
                    <circle cx="12" cy="18" r="1.5"></circle>
                    <circle cx="18" cy="18" r="1.5"></circle>
                  </svg>
                </button>
              </div>
            </div>

          </div>
        </div>

        <!-- SECTION 4 & 5: Premium Product Grid & Pagination -->
        <div class="rt-collection-content">
          {%- assign products_per_page = 24 -%}
          {%- if section.settings.enable_infinite_scroll == false -%}
            {%- assign products_per_page = section.settings.products_per_page -%}
          {%- endif -%}

          {%- paginate collection.products by products_per_page -%}
            
            {%- capture children -%}
              {%- for product in collection.products -%}
                <li
                  id="{{ section.id }}-{{ product.id }}"
                  class="rt-product-grid__item rt-collection-anim rt-fade-up"
                  data-product-title="{{ product.title | escape }}"
                  data-product-tags="{{ product.tags | join: ',' | downcase | escape }}"
                  data-product-type="{{ product.type | downcase | escape }}"
                  data-page="{{ paginate.current_page }}"
                  data-product-id="{{ product.id }}"
                  ref="cards[]"
                >
                  {% content_for 'block',
                    type: '_product-card',
                    id: 'product-card',
                    closest.product: product,
                    product_view_context: 'collection'
                  %}
                </li>
              {%- endfor -%}
            {%- endcapture -%}

            {%- if collection.products.size == 0 -%}
              <div class="main-collection-grid__empty" style="text-align: center; padding: 4rem 0;">
                <h2 class="main-collection-grid__empty-title h2" style="margin-bottom: 1rem;">
                  {{ 'content.no_products_found' | t }}
                </h2>
                <p>
                  {{ 'content.use_fewer_filters_html' | t: link: collection.url, class: 'main-collection-grid__empty-link' }}
                </p>
              </div>
            {%- else -%}
              
              <ul class="rt-product-grid" id="ResultsList" role="list">
                {{ children }}
              </ul>

              <!-- SECTION 5: Premium Pagination -->
              {%- if section.settings.enable_infinite_scroll == false and paginate.pages > 1 -%}
                <div class="rt-pagination rt-collection-anim rt-fade-up">
                  {% render 'pagination-controls', paginate: paginate %}
                </div>
              {%- elsif section.settings.enable_infinite_scroll -%}
                <span ref="viewMoreNext"></span>
              {%- endif -%}

            {%- endif -%}

          {%- endpaginate -%}
        </div>

      </results-list>
    </collection-component>

  </div>
</div>

{% schema %}
{
  "name": "RoyalTick Collection List",
  "class": "rt-collections-section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Luxury Hero Banner"
    },
    {
      "type": "text",
      "id": "rt_page_heading",
      "label": "Heading Override",
      "default": "Our Luxury Collection",
      "info": "Leave blank to display the collection title dynamically."
    },
    {
      "type": "richtext",
      "id": "rt_page_description",
      "label": "Description Override",
      "default": "<p>Discover handcrafted luxury watches for every lifestyle.</p>",
      "info": "Leave blank to display the collection description dynamically."
    },
    {
      "type": "image_picker",
      "id": "rt_banner_image",
      "label": "Hero Banner Background",
      "info": "Fallback to the collection featured image if empty."
    },
    {
      "type": "video",
      "id": "rt_banner_video",
      "label": "Hero Banner Video",
      "info": "If uploaded, this video will play in the background instead of the image."
    },
    {
      "type": "checkbox",
      "id": "rt_show_description",
      "label": "Show Description",
      "default": true
    },
    {
      "type": "header",
      "content": "Grid Layout"
    },
    {
      "type": "range",
      "id": "rt_columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 4
    },
    {
      "type": "select",
      "id": "rt_columns_mobile",
      "label": "Columns on Mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "header",
      "content": "Shopify Pagination Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_infinite_scroll",
      "label": "Auto-load products (Infinite Scroll)",
      "default": false
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page (Standard Pagination)",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 12
    },
    {
      "type": "header",
      "content": "Design & Animations"
    },
    {
      "type": "color",
      "id": "rt_background_color",
      "label": "Background Color",
      "default": "#0b0b0b"
    },
    {
      "type": "color",
      "id": "rt_accent_color",
      "label": "Accent Color (Gold)",
      "default": "#c9a227"
    },
    {
      "type": "checkbox",
      "id": "rt_enable_animation",
      "label": "Enable Entrance Animations",
      "default": true
    },
    {
      "type": "range",
      "id": "rt_section_spacing_top",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "label": "Section Spacing Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "rt_section_spacing_bottom",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "label": "Section Spacing Bottom",
      "default": 80
    },
    {
      "type": "header",
      "content": "Standard Layout Settings (Snippets Support)"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "Layout Type",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "product_card_size",
      "label": "Product Card Size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "mobile_product_card_size",
      "label": "Mobile Card Size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "small"
    },
    {
      "type": "select",
      "id": "product_grid_width",
      "label": "Product Grid Width",
      "options": [
        {
          "value": "centered",
          "label": "Centered"
        },
        {
          "value": "full-width",
          "label": "Full Width"
        }
      ],
      "default": "centered"
    },
    {
      "type": "checkbox",
      "id": "full_width_on_mobile",
      "label": "Full Width on Mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "columns_gap_horizontal",
      "label": "Horizontal Gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "columns_gap_vertical",
      "label": "Vertical Gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left Padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right Padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ]
}
{% endschema %}

