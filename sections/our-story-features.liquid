<div class="rt-story-wrapper">
  <div class="rt-features">
    <div class="rt-story-container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto;">
        <span class="rt-section-eyebrow">{{ section.settings.eyebrow | escape }}</span>
        <h2 class="rt-section-title">{{ section.settings.heading | escape }}</h2>
      </div>

      <div class="rt-features-grid">
        {%- for block in section.blocks -%}
          <div class="rt-features-card rt-reveal" style="transition-delay: {{ forloop.index0 | times: 0.05 }}s;">
            <div class="rt-features-icon">
              {%- if block.settings.svg_code != blank -%}
                {{ block.settings.svg_code }}
              {%- else -%}
                <svg viewBox="0 0 24 24">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              {%- endif -%}
            </div>
            <h4>{{ block.settings.title | escape }}</h4>
            <p>{{ block.settings.description | escape }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Our Story Features",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "THE ROYALTICK DIFFERENCE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Collectors Choose Us"
    }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "settings": [
        {
          "type": "html",
          "id": "svg_code",
          "label": "SVG Icon Code"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Feature description detail."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Story Features",
      "blocks": [
        {
          "type": "feature_card",
          "settings": {
            "title": "100% Authentic",
            "description": "Every single piece is verified by our experienced experts before arriving at your doorstep.",
            "svg_code": "<svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"m9 12 2 2 4-4\"/></svg>"
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "title": "Swiss Certified",
            "description": "Offering authentic collections direct from certified horological hubs in Switzerland.",
            "svg_code": "<svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>"
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "title": "Worldwide Shipping",
            "description": "Fully insured global courier transit guarantees your valuable delivery is completely safe.",
            "svg_code": "<svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z\"/></svg>"
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "title": "Secure Payments",
            "description": "State-of-the-art multi-encrypted pathways ensure transaction security at every step.",
            "svg_code": "<svg viewBox=\"0 0 24 24\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\" ry=\"2\"/><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"/></svg>"
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "title": "Luxury Packaging",
            "description": "Unbox a masterpiece inside customized premium leather cases crafted specifically for safekeeping.",
            "svg_code": "<svg viewBox=\"0 0 24 24\"><path d=\"M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\"/><polyline points=\"3.27 6.96 12 12.01 20.73 6.96\"/><line x1=\"12\" y1=\"22.08\" x2=\"12\" y2=\"12\"/></svg>"
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "title": "Lifetime Support",
            "description": "Dedicated assistance for repair routing, valuation queries, and servicing throughout your ownership.",
            "svg_code": "<svg viewBox=\"0 0 24 24\"><path d=\"M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z\"/></svg>"
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "title": "Premium Warranty",
            "description": "Every watch carries an extended guarantee plan to secure internal gear functions for generations.",
            "svg_code": "<svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><polyline points=\"9 11 11 13 15 9\"/></svg>"
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "title": "Professional Service",
            "description": "Our team of seasoned collectors offers advice tailored specifically to your portfolio goals.",
            "svg_code": "<svg viewBox=\"0 0 24 24\"><path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/></svg>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
