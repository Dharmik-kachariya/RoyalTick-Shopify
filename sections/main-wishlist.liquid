{% comment %} RoyalTick Premium Wishlist Section {% endcomment %}
{{ 'rt-wishlist.css' | asset_url | stylesheet_tag }}
<script src="{{ 'rt-wishlist.js' | asset_url }}" defer="defer"></script>

<div class="rt-wishlist" id="rt-wishlist-section">
  <div class="page-width rt-wishlist__container">
    <header class="rt-wishlist__header">
      <h1 class="rt-wishlist__title">MY WISHLIST</h1>
      <p class="rt-wishlist__subtitle">Your curated selection of exceptional timepieces.</p>
    </header>

    {% render 'rt-wishlist-card' %}
    <!-- Dynamic Wishlist Grid -->
    <div class="rt-wishlist__grid-wrapper" id="rt-wishlist-grid-wrapper" style="display: none;">
      <div class="rt-wishlist__grid" id="rt-wishlist-grid">
        <!-- Rendered dynamically by JavaScript -->
      </div>
    </div>
    
    <!-- Empty State -->
    <div id="rt-wishlist-empty" style="display: none;">
      {% render 'rt-empty-wishlist' %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Main Wishlist",
  "settings": []
}
{% endschema %}
