{{ 'rt-our-story-quick-links.css' | asset_url | stylesheet_tag }}

<section class="rt-ql-section">
  <div class="rt-story-container">
    <div class="rt-ql-header">
      <h2 class="rt-ql-heading">{{ section.settings.heading | escape }}</h2>
      <p class="rt-ql-description">{{ section.settings.description | escape }}</p>
    </div>
    
    <div class="rt-ql-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="rt-ql-card" {{ block.shopify_attributes }}>
          <div class="rt-ql-icon-wrapper">
            {%- case block.settings.icon -%}
              {%- when 'watch' -%}
                <svg class="rt-ql-icon" viewBox="0 0 24 24"><circle cx=\"12\" cy=\"12\" r=\"7\"/><rect x=\"9\" y=\"1\" width=\"6\" height=\"4\" rx=\"1\"/><rect x=\"9\" y=\"19\" width=\"6\" height=\"4\" rx=\"1\"/><path d=\"M12 9v3l2 2\"/></svg>
              {%- when 'sparkle' -%}
                <svg class="rt-ql-icon" viewBox="0 0 24 24"><path d=\"m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z\"/></svg>
              {%- when 'diamond' -%}
                <svg class="rt-ql-icon" viewBox="0 0 24 24"><path d=\"M6 3h12l4 6-10 12L2 9z\"/><path d=\"M11 3 8 9l4 12 4-12-3-6\"/><path d=\"M2 9h20\"/></svg>
              {%- when 'calendar' -%}
                <svg class="rt-ql-icon" viewBox="0 0 24 24"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"/><line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"/><line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"/><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"/></svg>
              {%- when 'user' -%}
                <svg class="rt-ql-icon" viewBox="0 0 24 24"><path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/></svg>
              {%- when 'shield' -%}
                <svg class="rt-ql-icon" viewBox="0 0 24 24"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>
              {%- when 'headset' -%}
                <svg class="rt-ql-icon" viewBox="0 0 24 24"><path d=\"M3 18v-6a9 9 0 0 1 18 0v6\"/><path d=\"M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z\"/></svg>
              {%- when 'help' -%}
                <svg class="rt-ql-icon" viewBox="0 0 24 24"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3\"/><line x1=\"12\" y1=\"17\" x2=\"12.01\" y2=\"17\"/></svg>
              {%- else -%}
                <svg class="rt-ql-icon" viewBox="0 0 24 24"><circle cx=\"12\" cy=\"12\" r=\"10\"/><line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"16\"/><line x1=\"8\" y1=\"12\" x2=\"16\" y2=\"12\"/></svg>
            {%- endcase -%}
          </div>
          <h3 class="rt-ql-card-title">{{ block.settings.title | escape }}</h3>
          <p class="rt-ql-card-text">{{ block.settings.text | escape }}</p>
          <span class="rt-ql-card-action">
            {{ block.settings.btn_text | escape }}
            <span class="rt-ql-card-arrow">&rarr;</span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<script src="{{ 'rt-our-story-quick-links.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Our Story Quick Links",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Continue Your Journey"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover the RoyalTick experience through our collections, services, and exclusive customer experiences."
    }
  ],
  "blocks": [
    {
      "type": "link_card",
      "name": "Quick Link Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "watch", "label": "Luxury Watch" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "diamond", "label": "Diamond" },
            { "value": "calendar", "label": "Calendar" },
            { "value": "user", "label": "User" },
            { "value": "shield", "label": "Shield" },
            { "value": "headset", "label": "Headset" },
            { "value": "help", "label": "Help Circle" }
          ],
          "default": "watch"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Link Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Card Description",
          "default": "Provide a brief description details."
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Label",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link Destination"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Story Quick Links"
    }
  ]
}
{% endschema %}
