{{ 'rt-brand-showcase.css' | asset_url | stylesheet_tag }}
<script src="{{ 'rt-brand-showcase.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.rt_section_spacing_top }}px;
    padding-bottom: {{ section.settings.rt_section_spacing_bottom }}px;
  }
  #rt-brand-showcase-{{ section.id }} {
    --rt-bg-color: {{ section.settings.rt_background_color }};
    --rt-card-radius: {{ section.settings.rt_card_radius }}px;
  }
{%- endstyle -%}

<div 
  id="rt-brand-showcase-{{ section.id }}" 
  class="rt-brand-showcase section-{{ section.id }}-padding"
  data-enable-animation="{{ section.settings.rt_enable_animation }}"
>
  <div class="rt-brand-showcase__container">
    
    <!-- Top Content / Header -->
    <div class="rt-brand-showcase__header rt-brand-showcase-anim rt-fade-up">
      {%- if section.settings.rt_eyebrow != blank -%}
        <span class="rt-brand-showcase__eyebrow">{{ section.settings.rt_eyebrow | escape }}</span>
      {%- endif -%}
      {%- if section.settings.rt_heading != blank -%}
        <h2 class="rt-brand-showcase__heading">{{ section.settings.rt_heading }}</h2>
      {%- endif -%}
      {%- if section.settings.rt_description != blank -%}
        <div class="rt-brand-showcase__description">
          {{ section.settings.rt_description }}
        </div>
      {%- endif -%}
      <div class="rt-brand-showcase__divider"></div>
    </div>

    <!-- Infinite Brand Logo Slider -->
    {%- if section.settings.rt_enable_marquee -%}
      <div class="rt-brand-showcase__marquee-wrapper{% if section.settings.rt_pause_on_hover %} rt-brand-showcase__marquee-wrapper--pause-hover{% endif %} rt-brand-showcase-anim rt-fade-up">
        <div class="rt-brand-showcase__marquee-inner">
          
          {%- capture marquee_content -%}
            {%- if section.blocks.size > 0 -%}
              {%- for block in section.blocks -%}
                <div class="rt-brand-showcase__logo-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 300 | image_tag:
                      loading: 'lazy',
                      class: 'rt-brand-showcase__logo-img',
                      alt: block.settings.brand_name | default: 'Brand Logo'
                    }}
                  {%- else -%}
                    <span class="rt-brand-showcase__logo-text">{{ block.settings.brand_name }}</span>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            {%- else -%}
              <!-- Default Luxury Brand Fallbacks -->
              {%- assign default_brands = "Rolex,Omega,TAG Heuer,Longines,Seiko,Tissot,Citizen,Casio,Breitling,Patek Philippe" | split: "," -%}
              {%- for brand in default_brands -%}
                <div class="rt-brand-showcase__logo-item">
                  <span class="rt-brand-showcase__logo-text">{{ brand }}</span>
                </div>
              {%- endfor -%}
            {%- endif -%}
          {%- endcapture -%}

          <div class="rt-brand-showcase__marquee-track{% if section.settings.rt_marquee_speed == 'slow' %} rt-brand-showcase__marquee-track--slow{% elsif section.settings.rt_marquee_speed == 'fast' %} rt-brand-showcase__marquee-track--fast{% endif %}">
            {{ marquee_content }}
          </div>
          <!-- Duplicate once in liquid for seamless scrolling on first render -->
          <div class="rt-brand-showcase__marquee-track{% if section.settings.rt_marquee_speed == 'slow' %} rt-brand-showcase__marquee-track--slow{% elsif section.settings.rt_marquee_speed == 'fast' %} rt-brand-showcase__marquee-track--fast{% endif %}">
            {{ marquee_content }}
          </div>
          
        </div>
      </div>
    {%- endif -%}

    <!-- Trust Cards Grid -->
    {%- if section.settings.rt_enable_cards -%}
      <div class="rt-brand-showcase__cards">
        
        <!-- Card 1: 100% Authentic Watches -->
        <div class="rt-brand-showcase__card rt-brand-showcase-anim rt-fade-up">
          {%- if section.settings.rt_show_icons -%}
            <div class="rt-brand-showcase__card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="7"></circle>
                <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
              </svg>
            </div>
          {%- endif -%}
          <h3 class="rt-brand-showcase__card-title">100% Authentic Watches</h3>
          <p class="rt-brand-showcase__card-desc">Certified genuine luxury timepieces with original certificates and papers.</p>
        </div>

        <!-- Card 2: Official Warranty -->
        <div class="rt-brand-showcase__card rt-brand-showcase-anim rt-fade-up">
          {%- if section.settings.rt_show_icons -%}
            <div class="rt-brand-showcase__card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                <path d="m9 12 2 2 4-4"></path>
              </svg>
            </div>
          {%- endif -%}
          <h3 class="rt-brand-showcase__card-title">Official Warranty</h3>
          <p class="rt-brand-showcase__card-desc">Guaranteed international coverage backing all luxury watch movements.</p>
        </div>

        <!-- Card 3: Secure Payments -->
        <div class="rt-brand-showcase__card rt-brand-showcase-anim rt-fade-up">
          {%- if section.settings.rt_show_icons -%}
            <div class="rt-brand-showcase__card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
            </div>
          {%- endif -%}
          <h3 class="rt-brand-showcase__card-title">Secure Payments</h3>
          <p class="rt-brand-showcase__card-desc">Encrypted 256-bit payment gateways securing transaction processing.</p>
        </div>

        <!-- Card 4: Worldwide Shipping -->
        <div class="rt-brand-showcase__card rt-brand-showcase-anim rt-fade-up">
          {%- if section.settings.rt_show_icons -%}
            <div class="rt-brand-showcase__card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="2" y1="12" x2="22" y2="12"></line>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
              </svg>
            </div>
          {%- endif -%}
          <h3 class="rt-brand-showcase__card-title">Worldwide Shipping</h3>
          <p class="rt-brand-showcase__card-desc">Insured international express courier dispatching to all countries.</p>
        </div>

        <!-- Card 5: Free Luxury Packaging -->
        <div class="rt-brand-showcase__card rt-brand-showcase-anim rt-fade-up">
          {%- if section.settings.rt_show_icons -%}
            <div class="rt-brand-showcase__card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="21 8 21 21 3 21 3 8"></polyline>
                <rect x="1" y="3" width="22" height="5"></rect>
                <line x1="10" y1="12" x2="14" y2="12"></line>
              </svg>
            </div>
          {%- endif -%}
          <h3 class="rt-brand-showcase__card-title">Free Luxury Packaging</h3>
          <p class="rt-brand-showcase__card-desc">Exquisite presentation boxes, leather pouches, and detailing tools included.</p>
        </div>

        <!-- Card 6: Easy Returns -->
        <div class="rt-brand-showcase__card rt-brand-showcase-anim rt-fade-up">
          {%- if section.settings.rt_show_icons -%}
            <div class="rt-brand-showcase__card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path>
                <polyline points="16 3 21 8 16 8"></polyline>
                <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path>
                <polyline points="8 21 3 16 8 16"></polyline>
              </svg>
            </div>
          {%- endif -%}
          <h3 class="rt-brand-showcase__card-title">Easy Returns</h3>
          <p class="rt-brand-showcase__card-desc">Hassle-free evaluation returns period backed by straightforward service.</p>
        </div>

      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "RoyalTick Trust Showcase",
  "tag": "section",
  "class": "rt-brand-showcase-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "rt_eyebrow",
      "label": "Eyebrow Text",
      "default": "TRUSTED WORLDWIDE"
    },
    {
      "type": "text",
      "id": "rt_heading",
      "label": "Heading",
      "default": "Authorized Luxury Watch Destination"
    },
    {
      "type": "richtext",
      "id": "rt_description",
      "label": "Description",
      "default": "<p>We proudly curate the world's finest luxury timepieces from internationally recognized brands, backed by authenticity, premium service and worldwide delivery.</p>"
    },
    {
      "type": "header",
      "content": "Brand Marquee Logo Settings"
    },
    {
      "type": "checkbox",
      "id": "rt_enable_marquee",
      "label": "Enable Logo Marquee",
      "default": true
    },
    {
      "type": "select",
      "id": "rt_marquee_speed",
      "label": "Marquee Speed",
      "options": [
        {
          "value": "slow",
          "label": "Slow"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "fast",
          "label": "Fast"
        }
      ],
      "default": "medium"
    },
    {
      "type": "checkbox",
      "id": "rt_pause_on_hover",
      "label": "Pause Marquee on Hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Trust Cards Settings"
    },
    {
      "type": "checkbox",
      "id": "rt_enable_cards",
      "label": "Enable Trust Cards Grid",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "rt_show_icons",
      "label": "Show Card Icons",
      "default": true
    },
    {
      "type": "range",
      "id": "rt_card_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Card Border Radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Colors & Layout"
    },
    {
      "type": "color",
      "id": "rt_background_color",
      "label": "Background Color",
      "default": "#0b0b0b"
    },
    {
      "type": "checkbox",
      "id": "rt_enable_animation",
      "label": "Enable Entrance Animations",
      "default": true
    },
    {
      "type": "range",
      "id": "rt_section_spacing_top",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "label": "Section Spacing Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "rt_section_spacing_bottom",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "label": "Section Spacing Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "brand_logo",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Brand Logo Image"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name",
          "default": "Luxury Brand"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RoyalTick Trust Showcase",
      "settings": {
        "rt_eyebrow": "TRUSTED WORLDWIDE",
        "rt_heading": "Authorized Luxury Watch Destination"
      }
    }
  ]
}
{% endschema %}
