{
  "sections": {
    "cart-section": {
      "type": "main-cart",
      "blocks": {
        "cart-page-title": {
          "type": "_cart-title",
          "static": true,
          "settings": {
            "title": "Cart",
            "show_count": true,
            "type_preset": "h4",
            "alignment": "left",
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {}
        },
        "cart-page-items": {
          "type": "_cart-products",
          "static": true,
          "settings": {
            "gap": 24,
            "image_ratio": "portrait",
            "dividers": true,
            "vendor": false,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {}
        },
        "cart-page-summary": {
          "type": "_cart-summary",
          "static": true,
          "settings": {
            "extend_summary": true,
            "background_color": "{{ settings.color_palette.color2 }}",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0
          },
          "blocks": {}
        }
      },
      "settings": {
        "section_width": "page-width",
        "background_color": "{{ settings.color_palette.background }}",
        "padding-block-start": 24,
        "padding-block-end": 0
      }
    },
    "luxury_recommendations": {
      "type": "luxury-cart-recommendations",
      "settings": {
        "title": "You May Also Like",
        "limit": 4
      }
    }
  },
  "order": [
    "cart-section",
    "luxury_recommendations"
  ]
}