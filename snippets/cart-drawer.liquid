{% doc %}
  Renders reusable cart drawer markup for both initial page loads and Section Rendering API responses.

  @param {boolean} [render_wrapper] - When true, wraps the drawer in the section wrapper that the Section Rendering API adds automatically.
{% enddoc %}

{%- liquid
  assign render_wrapper = render_wrapper | default: true, allow_false: true
-%}

{%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
  {{ 'rt-cart.css' | asset_url | stylesheet_tag }}
  {{ 'rt-cart-drawer.css' | asset_url | stylesheet_tag }}
  {% if render_wrapper %}
    <div
      id="shopify-section-cart-drawer-section"
      class="shopify-section"
    >
  {% endif %}

  <script
    type="module"
    src="{{ 'cart-drawer.js' | asset_url }}"
    fetchpriority="low"
  ></script>

  {% capture empty_cart_drawer_content %}
    <div
      class="cart-drawer__content rt-empty-cart"
      aria-label="{{ 'accessibility.cart' | t }}"
    >
      <div class="rt-empty-cart__icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
      </div>
      <h2
        class="rt-empty-cart__title"
        id="cart-drawer-heading"
      >
        Your Collection Awaits
      </h2>
      
      <p class="rt-empty-cart__subtitle">
        Discover timeless watches crafted for every occasion.
      </p>

      <a href="{{ routes.all_products_collection_url }}" class="rt-empty-cart__btn">
        Explore Collection
      </a>
    </div>
  {% endcapture %}

  <theme-drawer
    id="cart-drawer"
    data-skip-node-update
  >
    <dialog
      ref="panel"
      class="theme-drawer__dialog color-custom-drawer"
      aria-labelledby="cart-drawer-heading"
      cart-summary-sticky="true"
    >
      <cart-drawer-component
        {% if settings.auto_open_cart_drawer and template.name != 'cart' %}
          auto-open
        {% endif %}
      >
        <template id="empty-cart-template">
          {{ empty_cart_drawer_content }}
        </template>

        <div
          class="cart-drawer__inner{% if cart.empty? %} cart-drawer--empty{% endif %}"
          data-hydration-key="cart-drawer-inner"
        >
          {%- if cart.empty? -%}
            <div class="theme-drawer__header">
              <button
                on:click="#cart-drawer/close"
                class="theme-drawer__close-button cart-drawer__close-button--empty"
                type="button"
                aria-label="{{ 'actions.close' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>
          {%- else -%}
            {% capture cart_badge_html %}
              <span
                class="theme-drawer__badge{% if cart.item_count == 0 %} visually-hidden{% endif %}"
                aria-hidden="true"
                {% if cart.item_count <= 99 %}
                  data-maintain-ratio
                {% endif %}
              >
                {{- cart.item_count -}}
              </span>
              {% if cart.item_count > 0 %}
                <span class="visually-hidden">
                  {{ 'accessibility.cart_count' | t }}: {{ cart.item_count }}
                </span>
              {% endif %}
            {% endcapture %}
            {% assign cart_drawer_title = 'content.cart_title' | t %}
            {% render 'theme-drawer-header',
              title: cart_drawer_title,
              drawer_id: 'cart-drawer',
              heading_id: 'cart-drawer-heading',
              title_append: cart_badge_html
            %}
          {%- endif -%}

            {% capture cart_items_children %}
              {%- if cart.empty? -%}
                {{ empty_cart_drawer_content }}
              {%- else -%}
                <scroll-hint
                  class="cart-drawer__content"
                  aria-label="{{ 'accessibility.cart' | t }}"
                  style="--header-height: 60px;"
                >
                  <!-- Premium Free Shipping Bar -->
                  {% assign shipping_threshold = 200000 %} <!-- ₹2000 in cents -->
                  {% assign current_total = cart.total_price %}
                  {% assign remaining = shipping_threshold | minus: current_total %}
                  
                  <div class="rt-shipping-bar">
                    {% if remaining > 0 %}
                      {% assign progress = current_total | times: 100 | divided_by: shipping_threshold %}
                      <p class="rt-shipping-bar__text">
                        Spend <strong>{{ remaining | money }}</strong> more to unlock Free Express Shipping
                      </p>
                    {% else %}
                      {% assign progress = 100 %}
                      <p class="rt-shipping-bar__text">
                        <strong>Congratulations!</strong> You have unlocked Free Express Shipping.
                      </p>
                    {% endif %}
                    <div class="rt-shipping-bar__progress-bg">
                      <div class="rt-shipping-bar__progress-fill" style="width: {{ progress }}%;"></div>
                    </div>
                  </div>

                  <scroll-hint class="cart-drawer__items">
                    {% render 'cart-products', context: 'drawer' %}
                  </scroll-hint>

                  <div class="cart-drawer__summary">
                    {% render 'cart-summary', section_id: 'cart-drawer-section' %}
                  </div>
                  
                  <!-- Trust Icons Section -->
                  <div class="rt-trust-drawer">
                    <div class="rt-trust-drawer__item">
                      <span class="rt-trust-drawer__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                      </span>
                      Secure Checkout
                    </div>
                    <div class="rt-trust-drawer__item">
                      <span class="rt-trust-drawer__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                      </span>
                      100% Authentic
                    </div>
                    <div class="rt-trust-drawer__item">
                      <span class="rt-trust-drawer__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                      </span>
                      Easy Returns
                    </div>
                    <div class="rt-trust-drawer__item">
                      <span class="rt-trust-drawer__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                      </span>
                      Warranty
                    </div>
                  </div>

                </scroll-hint>
              {%- endif -%}
            {% endcapture %}
          {% render 'cart-items-component',
            children: cart_items_children,
            is_drawer: true,
            section_id: 'cart-drawer-section'
          %}
        </div>
      </cart-drawer-component>
    </dialog>
  </theme-drawer>

  {% if render_wrapper %}
    </div>
  {% endif %}
{%- endif -%}

{% stylesheet %}
  cart-drawer-component {
    --cart-drawer-padding: var(--theme-drawer-padding);
    --font-paragraph--line-height: 1;
    display: contents;
  }

  .cart-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }

  .cart-drawer__inner > .cart-items-component {
    flex: 1;
    min-height: 0;
    height: auto;
  }

  .cart-drawer__content {
    height: calc(100% - var(--header-height));
    display: flex;
    flex-direction: column;
    padding: 0;
    background-color: var(--color-background);
    flex-grow: 1;
    overflow-y: auto;
  }

  .cart-drawer__items {
    display: flex;
    flex-direction: column;
    padding-inline: var(--cart-drawer-padding);
    overflow-y: auto;
  }

  .cart-drawer__items .cart-items__table-row {
    padding-bottom: var(--gap-xl);
    border-bottom: var(--style-border-width) solid rgb(var(--color-foreground-rgb) / var(--opacity-10-25));
    margin-bottom: var(--gap-xl);
  }

  .cart-drawer__items .cart-items__table-row:has(+ .cart-items__nested-line) {
    border-bottom: none;
    margin-bottom: 0;
  }

  .cart-drawer__items .cart-items__table-row:last-child {
    border-bottom: none;
    padding-block-end: 0;
    margin-block-end: 0;
  }

  .cart-drawer__close-button--empty {
    margin-inline-start: auto;
  }

  .cart-drawer__summary {
    --cart-drawer-summary-padding: var(--padding-lg);

    position: sticky;
    bottom: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-xl);
    padding: var(--cart-drawer-summary-padding);
    margin-top: auto;
    background-color: var(--color-background);
    /* stylelint-disable-next-line color-named */
    mask-image: linear-gradient(to bottom, transparent, black var(--cart-drawer-summary-padding));

    @media screen and (min-width: 750px) {
      --cart-drawer-summary-padding: var(--padding-2xl);
    }
  }

  .theme-drawer__dialog[cart-summary-sticky='false'] .cart-drawer__summary {
    position: static;
    mask-image: none;
  }

  .theme-drawer__dialog[cart-summary-sticky='false'] .cart-drawer__items {
    overflow: unset;
  }

  .cart-actions summary {
    padding-inline: 0;
    padding-block: var(--padding-sm);
    line-height: 1.2;
    min-height: var(--minimum-touch-target);
  }

  .cart-drawer__summary .cart__summary-totals:not(:has(.cart__subtotal-container:empty)) {
    border-block-start: var(--style-border-width) solid rgb(var(--color-foreground-rgb) / var(--opacity-10-25));
    padding-block-start: var(--padding-2xl);
  }

  .cart-drawer__summary .cart-note {
    @media screen and (min-width: 750px) {
      margin-block-start: var(--margin-3xs);
    }
  }

  .cart-drawer--empty .cart-drawer__content {
    text-align: center;
    align-items: center;
    justify-content: center;
    min-height: auto;
  }

  .cart-drawer--empty .cart-drawer__items {
    padding-inline: 0;
  }

  cart-drawer-component:not(:has(.cart-form)) .cart-drawer__content {
    text-align: center;
    align-items: center;
    justify-content: center;
  }

  cart-drawer-component:not(:has(.cart-form)) .cart-drawer__items {
    padding-inline: 0;
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    html:active-view-transition-type(empty-cart-drawer) {
      .theme-drawer__close-button {
        view-transition-name: cart-drawer-close-button;
      }
    }
  }

  :active-view-transition {
    .cart-drawer__header,
    .cart-drawer__content {
      background: transparent;
    }
  }
{% endstylesheet %}
