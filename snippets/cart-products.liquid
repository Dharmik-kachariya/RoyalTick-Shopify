{% doc %}
  Cart Products (Strict Luxury UI Rebuild)
  Renders the cart products list.
{% enddoc %}

{%- if cart != empty -%}
  <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart-form">
    <div class="cart__items" id="main-cart-items" data-id="{{ section.id }}">

      <span class="visually-hidden" ref="cartItemCount" style="display:none">{{ cart.item_count }}</span>
      
      <!-- New DIV-based Product List (Replaces Table) -->
      <div class="luxury-cart-items-wrapper">
        {% for item in cart.items %}
          <div class="luxury-product-card" id="CartItem-{{ item.index }}" ref="cartItemRows[]" data-key="{{ item.key }}" data-parent-key="{{ item.key }}">
            
            <!-- Product Image -->
            <div class="luxury-product-media">
              {% if item.image %}
                {{ item.image | image_url: width: 400 | image_tag: loading: 'lazy' }}
              {% else %}
                {{ 'product-apparel-1' | placeholder_svg_tag }}
              {% endif %}
            </div>

            <!-- Product Details & Actions -->
            <div class="luxury-product-content">
              
              <!-- Top Row: Info + Price -->
              <div class="luxury-product-top">
                <div class="luxury-product-info">
                  {% if item.product.vendor %}
                    <span class="luxury-product-vendor">{{ item.product.vendor }}</span>
                  {% endif %}
                  
                  <a href="{{ item.url }}" class="luxury-product-title">{{ item.product.title | escape }}</a>
                  
                  {%- if item.product.has_only_default_variant == false or item.properties.size != 0 or item.selling_plan_allocation != nil -%}
                    <div class="luxury-product-variant">
                      {%- if item.product.has_only_default_variant == false -%}
                        {%- for option in item.options_with_values -%}
                          {{ option.name }}: {{ option.value }}{% unless forloop.last %}, {% endunless %}
                        {%- endfor -%}
                      {%- endif -%}
                    </div>
                  {%- endif -%}

                  {% if item.sku != blank %}
                    <div class="luxury-product-sku">SKU: {{ item.sku }}</div>
                  {% endif %}

                  <div class="luxury-badge-row">
                    {% if item.variant.inventory_management and item.variant.inventory_policy == 'deny' and item.variant.inventory_quantity <= 5 and item.variant.inventory_quantity > 0 %}
                      <span class="luxury-badge">Low Stock ({{ item.variant.inventory_quantity }})</span>
                    {% else %}
                      <span class="luxury-badge luxury-badge--success">In Stock</span>
                    {% endif %}
                  </div>
                </div>

                <!-- Price Column -->
                <div class="luxury-product-price">
                  {%- liquid
                    if settings.currency_code_enabled_cart_items
                      assign price = item.final_line_price | money_with_currency
                    else
                      assign price = item.final_line_price | money
                    endif
                  -%}
                  <span class="luxury-price-final">{{ price }}</span>
                  {% if item.original_line_price != item.final_line_price %}
                    {%- liquid
                      if settings.currency_code_enabled_cart_items
                        assign original_price = item.original_line_price | money_with_currency
                      else
                        assign original_price = item.original_line_price | money
                      endif
                    -%}
                    <span class="luxury-price-original">{{ original_price }}</span>
                  {% endif %}
                </div>
              </div>

              <!-- Bottom Row: Quantity + Actions -->
              <div class="luxury-product-actions">
                {% render 'quantity-selector',
                  product: item.product,
                  variant: item.variant,
                  in_cart_quantity: item.quantity,
                  line_index: forloop.index0,
                  can_update_quantity: true
                %}
                
                <div class="luxury-action-links">
                  <button type="button" class="luxury-action-link" disabled title="Coming Soon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    Wishlist
                  </button>
                  <button type="button" class="luxury-action-link" disabled title="Coming Soon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                    Save
                  </button>
                  
                  <button 
                    class="luxury-action-link luxury-action-link--remove cart-items__remove" 
                    type="button" 
                    aria-label="{{ 'accessibility.remove_item' | t: title: item.title | escape }}"
                    on:click="/onLineItemRemove/{{ item.index }}"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                    Remove
                  </button>
                </div>
              </div>

              <div class="cart-item__error" id="Line-item-error-{{ item.index }}" role="alert">
                <small class="cart-item__error-text"></small>
              </div>

            </div>
          </div>
        {% endfor %}
      </div>

    </div>
  </form>
{%- endif -%}
